--GamePlace ID Copy & Game Job ID

-- LocalScript in StarterGui
local Players = game:GetService("Players")
local player = Players.LocalPlayer
local screenGui = Instance.new("ScreenGui")
screenGui.Name = "IDGui"
screenGui.Parent = player:WaitForChild("PlayerGui")

-- Create a Frame
local frame = Instance.new("Frame")
frame.Size = UDim2.new(0.4, 0, 0.4, 0)
frame.Position = UDim2.new(0.3, 0, 0.3, 0)
frame.BackgroundColor3 = Color3.new(1, 1, 1)
frame.Parent = screenGui

-- Close button
local closeButton = Instance.new("TextButton")
closeButton.Size = UDim2.new(0.15, 0, 0.15, 0)
closeButton.Position = UDim2.new(0.85, 0, 0, 0)
closeButton.Text = "Close"
closeButton.TextScaled = true
closeButton.Parent = frame

-- Create a TextLabel for Game ID
local gameIdLabel = Instance.new("TextLabel")
gameIdLabel.Size = UDim2.new(1, 0, 0.2, 0)
gameIdLabel.Position = UDim2.new(0, 0, 0.2, 0)

-- Ensure we get the correct Game ID dynamically
gameIdLabel.Text = "Game ID: " .. game.PlaceId  -- Changed from game.GameId to game.PlaceId
gameIdLabel.TextScaled = true
gameIdLabel.Parent = frame

-- Create a TextLabel for Job ID
local jobIdLabel = Instance.new("TextLabel")
jobIdLabel.Size = UDim2.new(1, 0, 0.2, 0)
jobIdLabel.Position = UDim2.new(0, 0, 0.45, 0)

-- Ensure we get the correct Job ID dynamically
jobIdLabel.Text = "Job ID: " .. game.JobId  -- This should be fine as is
jobIdLabel.TextScaled = true
jobIdLabel.Parent = frame

-- Create a Copy button for Game ID
local copyGameIdButton = Instance.new("TextButton")
copyGameIdButton.Size = UDim2.new(1, 0, 0.2, 0)
copyGameIdButton.Position = UDim2.new(0, 0, 0.7, 0)
copyGameIdButton.Text = "Copy Game ID"
copyGameIdButton.TextScaled = true
copyGameIdButton.Parent = frame

-- Create a Copy button for Job ID
local copyJobIdButton = Instance.new("TextButton")
copyJobIdButton.Size = UDim2.new(1, 0, 0.2, 0)
copyJobIdButton.Position = UDim2.new(0, 0, 0.9, 0)
copyJobIdButton.Text = "Copy Job ID"
copyJobIdButton.TextScaled = true
copyJobIdButton.Parent = frame

-- Function to copy text to clipboard and change color temporarily
local function copyToClipboard(text, label)
    setclipboard(text)
    label.BackgroundColor3 = Color3.new(0, 1, 0) -- Change to green
    wait(1) -- Wait for 1 second
    label.BackgroundColor3 = Color3.new(1, 1, 1) -- Change back
end

-- Connect buttons to copy functions with feedback
copyGameIdButton.MouseButton1Click:Connect(function()
    copyToClipboard(tostring(game.PlaceId), gameIdLabel)  -- Changed from game.GameId to game.PlaceId
    print("Game ID copied: " .. game.PlaceId) -- Optional feedback
end)

copyJobIdButton.MouseButton1Click:Connect(function()
    copyToClipboard(tostring(game.JobId), jobIdLabel)
    print("Job ID copied: " .. game.JobId) -- Optional feedback
end)

-- Connect close button to remove GUI
closeButton.MouseButton1Click:Connect(function()
    screenGui:Destroy()
end)

-- Dragging functionality
local isDragging = false
local dragStart = nil
local startPos = nil

-- Function to handle the beginning of the dragging process
frame.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        isDragging = true
        dragStart = input.Position
        startPos = frame.Position
    end
end)

-- Function to update the position of the frame while dragging
frame.InputChanged:Connect(function(input)
    if isDragging and input.UserInputType == Enum.UserInputType.MouseMovement then
        local delta = input.Position - dragStart
        frame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
end)

-- Function to handle the end of the dragging process
frame.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        isDragging = false
    end
end)
