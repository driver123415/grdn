local function refreshTargetBtnText()
    if #CONFIG.TargetUnits == 0 then
        TargetDropdownBtn.Text = "📋 Pilih Unit Target (0 Terpilih)"
    elseif #CONFIG.TargetUnits == 1 then
        TargetDropdownBtn.Text = "Target: " .. CONFIG.TargetUnits[1]
    else
        TargetDropdownBtn.Text = "Target: " .. #CONFIG.TargetUnits .. " Unit Terpilih"
    end
end

local function updateDropdownList()
    for _, child in ipairs(DropdownScroll:GetChildren()) do
        if child:IsA("TextButton") then child:Destroy() end
    end
    
    local uniqueUnits = {}
    local mapFolder = workspace:FindFirstChild("Map")
    local entitiesFolder = mapFolder and mapFolder:FindFirstChild("Entities")
    
    if entitiesFolder then
        for _, unit in ipairs(entitiesFolder:GetChildren()) do
            -- Abaikan border/objek aneh, hanya ambil yang awalan "unit_" atau "enemy_" yang model
            if not uniqueUnits[unit.Name] and (unit.Name:match("unit_") or unit:FindFirstChild("HumanoidRootPart") or unit:GetAttribute("ID")) then
                uniqueUnits[unit.Name] = true
                
                local isSelected = table.find(CONFIG.TargetUnits, unit.Name) ~= nil
                
                local btn = Instance.new("TextButton")
                btn.Size = UDim2.new(1, 0, 0, 20)
                btn.BackgroundColor3 = isSelected and Color3.fromRGB(60, 120, 60) or Color3.fromRGB(40, 40, 55)
                btn.Text = unit.Name
                btn.TextColor3 = Color3.fromRGB(255, 255, 255)
                btn.Font = Enum.Font.Gotham
                btn.TextSize = 10
                btn.BorderSizePixel = 0
                btn.Parent = DropdownScroll
                
                btn.MouseButton1Click:Connect(function()
                    local idx = table.find(CONFIG.TargetUnits, unit.Name)
                    if idx then
                        table.remove(CONFIG.TargetUnits, idx)
                        btn.BackgroundColor3 = Color3.fromRGB(40, 40, 55)
                    else
                        table.insert(CONFIG.TargetUnits, unit.Name)
                        btn.BackgroundColor3 = Color3.fromRGB(60, 120, 60)
                    end
                    refreshTargetBtnText()
                end)
            end
        end
    end
    DropdownScroll.CanvasSize = UDim2.new(0, 0, 0, DropdownLayout.AbsoluteContentSize.Y)
end

TargetDropdownBtn.MouseButton1Click:Connect(function()
    DropdownScroll.Visible = not DropdownScroll.Visible
    if DropdownScroll.Visible then
        updateDropdownList()
        CfgCard.Size = UDim2.new(1, 0, 0, 210) 
        MainFrame.ClipsDescendants = false -- Penting agar dropdown tidak terpotong ke bawah
    else
        CfgCard.Size = UDim2.new(1, 0, 0, 120)
        MainFrame.ClipsDescendants = true
    end
end)

-- ============================================================
-- CORE LOGIC (AUTO UPGRADE DENGAN ANTRIAN PRIORITAS)
-- ============================================================
local UpgradeRemote = ReplicatedStorage:WaitForChild("RemoteFunctions"):WaitForChild("UpgradeUnit")

function runUpgrader()
    addLog("Mulai Sistem Prioritas Upgrade!", Color3.fromRGB(100, 255, 100))

    while isRunning do
        local mapFolder = workspace:FindFirstChild("Map")
        local entitiesFolder = mapFolder and mapFolder:FindFirstChild("Entities")
        
        if not entitiesFolder or #CONFIG.TargetUnits == 0 then
            task.wait(CONFIG.UpgradeInterval)
            continue
        end

        local totalFound = 0
        
        -- SISTEM PRIORITAS: Script mengeksekusi urut berdasarkan TargetUnits array
        for _, targetName in ipairs(CONFIG.TargetUnits) do
            if not isRunning then break end
            
            local currentUnitIDs = {}
            for _, unit in pairs(entitiesFolder:GetChildren()) do
                if unit.Name == targetName then
                    local unitID = unit:GetAttribute("ID") 
                    if unitID then table.insert(currentUnitIDs, unitID) end
                end
            end
            
            totalFound = totalFound + #currentUnitIDs
            
            -- Eksekusi upgrade untuk unit ini terlebih dahulu
            if #currentUnitIDs > 0 then
                addLog("Upgrading ["..targetName.."] ("..#currentUnitIDs.." unit)", Color3.fromRGB(100, 200, 255))
                for _, id in ipairs(currentUnitIDs) do
                    if not isRunning then break end
                    task.spawn(function()
                        pcall(function() UpgradeRemote:InvokeServer(id) end)
                    end)
                end
            end
        end

        CountText.Text = "Total Unit Target: " .. totalFound
        task.wait(CONFIG.UpgradeInterval)
    end
end

