-- FITUR BARU: AUTO WAVE DETECTOR & TOGGLE
-- ============================================================
local function getWaveText()
    local pGui = LocalPlayer:FindFirstChild("PlayerGui")
    if not pGui then return nil end
    local ggn = pGui:FindFirstChild("GameGuiNoInset")
    if not ggn then return nil end
    local screen = ggn:FindFirstChild("Screen")
    if not screen then return nil end
    local top = screen:FindFirstChild("Top")
    if not top then return nil end
    local info = top:FindFirstChild("GameInfo")
    if not info then return nil end
    local content = info:FindFirstChild("Content")
    if not content then return nil end
    local waves = content:FindFirstChild("Waves")
    if not waves then return nil end
    local title = waves:FindFirstChild("Title")
    if not title then return nil end
    
    return title.Text
end

task.spawn(function()
    while task.wait(1) do
        local curWave = getWaveText()
        
        -- [ PERBAIKAN BLINKING FIX ]: Hanya update jika ada teks baru
        if curWave and curWave ~= "" and curWave ~= lastWaveText then
            lastWaveText = curWave
            WaveTextDisplay.Text = "Wave: " .. curWave
            
            -- Eksekusi logika On/Off berdasarkan Config
            if CONFIG.EnableWaveControl then
                if curWave == CONFIG.StartWave and not isRunning then
                    addLog("🎯 Auto-Start dipicu oleh Wave!", Color3.fromRGB(100, 255, 100))
                    toggleScript()
                elseif curWave == CONFIG.StopWave and isRunning then
                    addLog("🛑 Auto-Stop dipicu oleh Wave!", Color3.fromRGB(255, 100, 100))
                    toggleScript()
                end
            end
        end
    end
end)

