-- FITUR BARU: AUTO WAVE DETECTOR MATEMATIS
-- ============================================================
local function getWaveText()
    local pGui = LocalPlayer:FindFirstChild("PlayerGui")
    if not pGui then return nil end
    local ggn = pGui:FindFirstChild("GameGuiNoInset")
    if not ggn then return nil end
    local screen = ggn:FindFirstChild("Screen")
    if not screen then return nil end
    local top = screen:FindFirstChild("Top")
    if not top then return nil end
    local info = top:FindFirstChild("GameInfo")
    if not info then return nil end
    local content = info:FindFirstChild("Content")
    if not content then return nil end
    local waves = content:FindFirstChild("Waves")
    if not waves then return nil end
    local title = waves:FindFirstChild("Title")
    if not title then return nil end
    
    return title.Text
end

task.spawn(function()
    while task.wait(1) do
        local curWaveText = getWaveText()
        
        if curWaveText and curWaveText ~= "" then
            WaveTextDisplay.Text = "Wave: " .. curWaveText
            
            -- Ekstrak angka murni dari string (Contoh "Level 1: Wave 9 / 20" -> diambil angka 9)
            local extractedNumStr = string.match(curWaveText, "Wave%s*(%d+)")
            if extractedNumStr then
                local currentWaveNum = tonumber(extractedNumStr)
                
                -- Hanya proses jika wave berganti
                if currentWaveNum ~= lastWaveNum then
                    lastWaveNum = currentWaveNum
                    
                    if CONFIG.WaveControl then
                        if currentWaveNum == CONFIG.StartWave and not isRunning then
                            addLog("🎯 Wave " .. currentWaveNum .. " Tercapai! Auto-Start ON", Color3.fromRGB(100, 255, 100))
                            toggleScript()
                        elseif currentWaveNum == CONFIG.StopWave and isRunning then
                            addLog("🛑 Wave " .. currentWaveNum .. " Tercapai! Auto-Stop ON", Color3.fromRGB(255, 100, 100))
                            toggleScript()
                        end
                    end
                end
            end
        end
    end
end)

