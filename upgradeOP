local function updateDropdownList()
    -- Bersihkan list lama
    for _, child in ipairs(DropdownScroll:GetChildren()) do
        if child:IsA("TextButton") then child:Destroy() end
    end
    
    local uniqueUnits = {}
    local mapFolder = workspace:FindFirstChild("Map")
    local entitiesFolder = mapFolder and mapFolder:FindFirstChild("Entities")
    
    if entitiesFolder then
        for _, unit in ipairs(entitiesFolder:GetChildren()) do
            if unit:IsA("Model") and not uniqueUnits[unit.Name] then
                uniqueUnits[unit.Name] = true
                
                local btn = Instance.new("TextButton")
                btn.Size = UDim2.new(1, 0, 0, 20)
                btn.BackgroundColor3 = Color3.fromRGB(40, 40, 55)
                btn.Text = unit.Name
                btn.TextColor3 = Color3.fromRGB(220, 220, 220)
                btn.Font = Enum.Font.Gotham
                btn.TextSize = 10
                btn.BorderSizePixel = 0
                btn.Parent = DropdownScroll
                
                btn.MouseButton1Click:Connect(function()
                    CONFIG.TargetUnit = unit.Name
                    TargetDropdownBtn.Text = "Target: " .. unit.Name
                    DropdownScroll.Visible = false
                    CfgCard.Size = UDim2.new(1, 0, 0, 85) -- Kembalikan ukuran card
                    addLog("Target diubah ke: " .. unit.Name, Color3.fromRGB(255, 200, 100))
                end)
            end
        end
    end
    
    -- Sesuaikan tinggi canvas
    DropdownScroll.CanvasSize = UDim2.new(0, 0, 0, DropdownLayout.AbsoluteContentSize.Y)
end

TargetDropdownBtn.MouseButton1Click:Connect(function()
    DropdownScroll.Visible = not DropdownScroll.Visible
    if DropdownScroll.Visible then
        updateDropdownList()
        CfgCard.Size = UDim2.new(1, 0, 0, 170) -- Perbesar card untuk menampilkan dropdown
    else
        CfgCard.Size = UDim2.new(1, 0, 0, 85)
    end
end)

-- ============================================================
-- CORE LOGIC (AUTO UPGRADE)
-- ============================================================
local UpgradeRemote = ReplicatedStorage:WaitForChild("RemoteFunctions"):WaitForChild("UpgradeUnit")

function runUpgrader()
    addLog("Sistem Auto-Upgrade Aktif!", Color3.fromRGB(100, 255, 100))

    while isRunning do
        local mapFolder = workspace:FindFirstChild("Map")
        local entitiesFolder = mapFolder and mapFolder:FindFirstChild("Entities")
        
        if not entitiesFolder then
            task.wait(CONFIG.UpgradeInterval)
            continue
        end

        local upgradableIDs = {}
        for _, unit in pairs(entitiesFolder:GetChildren()) do
            if unit.Name == CONFIG.TargetUnit then
                local unitID = unit:GetAttribute("ID") 
                if unitID then table.insert(upgradableIDs, unitID) end
            end
        end

        unitsFound = #upgradableIDs
        CountText.Text = "Unit Ditemukan: " .. unitsFound

        if unitsFound > 0 then
            addLog("Mengirim sinyal upgrade ke " .. unitsFound .. " unit...", Color3.fromRGB(100, 200, 255))
            for _, id in ipairs(upgradableIDs) do
                if not isRunning then break end
                task.spawn(function()
                    pcall(function() UpgradeRemote:InvokeServer(id) end)
                end)
            end
        end

        task.wait(CONFIG.UpgradeInterval)
    end
end

