-- =========================================================
-- [ULTRA-FAST AUTO FARM] WORKSPACE POSITION TELEPORT
-- =========================================================

local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer

print("🥚 Ultra-Fast Auto-Collect (Berdasarkan Position) Aktif!")

-- Fungsi untuk mendapatkan telur terdekat langsung dari Workspace
local function getClosestEgg()
    local character = LocalPlayer.Character
    if not character or not character:FindFirstChild("HumanoidRootPart") then return nil end
    
    local playerPos = character.HumanoidRootPart.Position
    local closestEgg = nil
    local shortestDistance = math.huge

    -- MENCARI LANGSUNG DI WORKSPACE (Jauh lebih ringan dan efisien)
    for _, obj in pairs(workspace:GetChildren()) do
        
        -- Deteksi nama dan wujud fisiknya
        if obj.Name == "Collectable" and obj:IsA("BasePart") then
            local prompt = obj:FindFirstChildWhichIsA("ProximityPrompt")
            
            -- Pastikan prompt-nya aktif
            if prompt and prompt.Enabled then
                -- Mengambil jarak dari properti Position
                local distance = (obj.Position - playerPos).Magnitude
                
                if distance < shortestDistance then
                    shortestDistance = distance
                    closestEgg = obj
                end
            end
        end
    end
    
    return closestEgg
end

-- Loop utama eksekusi
while task.wait(0.5) do
    local character = LocalPlayer.Character
    local targetEgg = getClosestEgg()
    
    if targetEgg and character and character:FindFirstChild("HumanoidRootPart") then
        local prompt = targetEgg:FindFirstChildWhichIsA("ProximityPrompt")
        
        if prompt then
            -- MENGAMBIL KOORDINAT DARI PROPERTIES "POSITION"
            -- Kita tambah Vector3.new(0, 3, 0) agar karakter tidak tersangkut di dalam tanah
            local targetPosition = targetEgg.Position + Vector3.new(0, 3, 0)
            
            -- Teleport karakter ke koordinat Position tersebut
            -- (Di Roblox, memindahkan karakter fisik wajib dibungkus dengan CFrame)
            character:PivotTo(CFrame.new(targetPosition))
            
            -- Tunggu server memuat posisi baru
            task.wait(0.3)
            
            -- Ambil telurnya
            if fireproximityprompt then
                fireproximityprompt(prompt)
            else
                prompt.HoldDuration = 0
                prompt:InputHoldBegin()
                prompt:InputHoldEnd()
            end
            
            -- Istirahat sebentar sebelum pindah ke telur lain
            task.wait(0.5)
        end
    end
end
