local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer

print("🥚 Smart Auto-Collect (Closest First) Aktif!")

-- Fungsi khusus untuk mencari 1 telur paling dekat
local function getClosestEgg()
    local character = LocalPlayer.Character
    if not character or not character:FindFirstChild("HumanoidRootPart") then return nil end
    
    local playerPos = character.HumanoidRootPart.Position
    local closestEgg = nil
    local shortestDistance = math.huge -- Set jarak awal ke tak terhingga (infinity)

    -- Geledah seluruh map
    for _, obj in pairs(workspace:GetDescendants()) do
        if obj.Name == "Collectable" and obj:IsA("BasePart") then
            local prompt = obj:FindFirstChildWhichIsA("ProximityPrompt")
            
            -- Pastikan prompt-nya ada dan belum diambil orang lain (Enabled)
            if prompt and prompt.Enabled then
                -- Hitung jarak dari pemain ke telur menggunakan .Magnitude
                local distance = (obj.Position - playerPos).Magnitude
                
                -- Jika jarak ini lebih pendek dari yang sebelumnya, jadikan target utama
                if distance < shortestDistance then
                    shortestDistance = distance
                    closestEgg = obj
                end
            end
        end
    end
    
    return closestEgg
end

-- Loop Utama: Teleport -> Ambil -> Cari lagi
while task.wait(0.5) do
    local character = LocalPlayer.Character
    
    -- Panggil fungsi radar jarak terdekat
    local targetEgg = getClosestEgg()
    
    if targetEgg and character and character:FindFirstChild("HumanoidRootPart") then
        local prompt = targetEgg:FindFirstChildWhichIsA("ProximityPrompt")
        
        if prompt then
            -- 1. Teleport menggunakan PivotTo (Lebih stabil dari CFrame biasa)
            -- Angka Vector3.new(0, 3, 0) agar muncul di atas telur, bukan di bawah tanah
            local targetCFrame = targetEgg.CFrame + Vector3.new(0, 3, 0)
            character:PivotTo(targetCFrame)
            
            -- 2. Beri waktu server menyadari posisi barumu (Wajib ada!)
            task.wait(0.3)
            
            -- 3. Eksekusi Proximity Prompt (Ambil Telur)
            if fireproximityprompt then
                fireproximityprompt(prompt)
            else
                prompt.HoldDuration = 0
                prompt:InputHoldBegin()
                prompt:InputHoldEnd()
            end
            
            -- 4. Jeda istirahat sebelum mencari telur selanjutnya (Mencegah kick)
            task.wait(0.5)
        end
    end
end
