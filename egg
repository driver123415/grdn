local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local Character = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
local HumanoidRootPart = Character:WaitForChild("HumanoidRootPart")

local CollectDelay = 0.5  -- jeda antar egg (detik)
local TeleportOffset = Vector3.new(0, 3, 0) -- offset agar tidak nyangkut di tanah

-- Fungsi cari semua ProximityPrompt di sekitar area
local function getProximityPromptNear(position, radius)
    for _, obj in ipairs(workspace:GetDescendants()) do
        if obj:IsA("ProximityPrompt") then
            local part = obj.Parent
            if part and part:IsA("BasePart") then
                local dist = (part.Position - position).Magnitude
                if dist <= radius then
                    return obj
                end
            end
        end
    end
    return nil
end

-- Fungsi fire ProximityPrompt
local function fireProximity(prompt)
    local success, err = pcall(function()
        fireproximityprompt(prompt) -- method executor
    end)
    if not success then
        -- fallback manual trigger
        pcall(function()
            prompt:InputHoldBegin()
            task.wait(0.1)
            prompt:InputHoldEnd()
        end)
    end
end

-- Fungsi utama collect semua egg
local function collectAllEggs()
    local collected = 0
    local failed = 0

    while true do
        -- Step 1: Cari semua Collectable di Workspace
        local collectables = {}
        for _, obj in ipairs(workspace:GetChildren()) do
            if obj.Name == "Collectable" then
                table.insert(collectables, obj)
            end
        end

        -- Kalau tidak ada lagi, selesai
        if #collectables == 0 then
            print("[AutoEgg] Semua egg sudah dikumpulkan! Total: " .. collected)
            break
        end

        print("[AutoEgg] Ditemukan " .. #collectables .. " egg tersisa...")

        local foundNew = false

        for _, collectable in ipairs(collectables) do
            -- Pastikan object masih ada
            if not collectable or not collectable.Parent then
                continue
            end

            -- Step 2: Ambil posisi CFrame
            local targetPosition
            local success = pcall(function()
                if collectable:IsA("BasePart") then
                    targetPosition = collectable.Position
                elseif collectable:FindFirstChildWhichIsA("BasePart") then
                    targetPosition = collectable:FindFirstChildWhichIsA("BasePart").Position
                elseif collectable.PrimaryPart then
                    targetPosition = collectable.PrimaryPart.Position
                end
            end)

            if not success or not targetPosition then
                failed = failed + 1
                continue
            end

            -- Step 3: Teleport LocalPlayer ke posisi egg
            HumanoidRootPart.CFrame = CFrame.new(targetPosition + TeleportOffset)
            task.wait(0.2) -- tunggu sebentar setelah teleport

            -- Step 4: Cari & fire ProximityPrompt di sekitar
            local prompt = getProximityPromptNear(targetPosition, 10)
            if prompt then
                fireProximity(prompt)
                collected = collected + 1
                foundNew = true
                print("[AutoEgg] Collected egg #" .. collected .. " di " .. tostring(targetPosition))
                task.wait(CollectDelay)
            else
                -- Tidak ada prompt ditemukan, skip
                failed = failed + 1
            end
        end

        -- Kalau satu putaran tidak ada yang baru, keluar
        if not foundNew then
            print("[AutoEgg] Tidak ada egg baru yang bisa diambil. Selesai.")
            break
        end

        task.wait(1) -- jeda sebelum scan ulang
    end

    print("[AutoEgg] Selesai! Berhasil: " .. collected .. " | Gagal: " .. failed)
end

-- Jalankan
print("[AutoEgg] Script dimulai...")
collectAllEggs()
