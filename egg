local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer

print("--- [DEBUG] Script Dimulai 1 ---")

local function getClosestEgg()
    local character = LocalPlayer.Character
    if not character then 
        print("DEBUG: Karakter belum spawn.")
        return nil 
    end
    
    local hrp = character:FindFirstChild("HumanoidRootPart")
    if not hrp then 
        print("DEBUG: HumanoidRootPart tidak ditemukan.")
        return nil 
    end
    
    local playerPos = hrp.Position
    local closestEgg = nil
    local shortestDistance = math.huge
    local foundAny = false

    -- Mencari telur
    for _, obj in pairs(workspace:GetChildren()) do
        if obj.Name == "Collectable" and obj:IsA("BasePart") then
            foundAny = true
            local prompt = obj:FindFirstChildWhichIsA("ProximityPrompt")
            
            if prompt and prompt.Enabled then
                local distance = (obj.Position - playerPos).Magnitude
                if distance < shortestDistance then
                    shortestDistance = distance
                    closestEgg = obj
                end
            end
        end
    end
    
    if not foundAny then
        print("DEBUG: Tidak ada objek bernama 'Collectable' di Workspace.")
    end
    
    return closestEgg
end

-- Loop Eksekusi
while task.wait(1) do
    print("--- [DEBUG] Mencari target terdekat... ---")
    
    local character = LocalPlayer.Character
    local targetEgg = getClosestEgg()
    
    if targetEgg then
        local hrp = character:FindFirstChild("HumanoidRootPart")
        local prompt = targetEgg:FindFirstChildWhichIsA("ProximityPrompt")
        
        if hrp and prompt then
            local targetPos = targetEgg.Position + Vector3.new(0, 3, 0)
            local distance = (targetEgg.Position - hrp.Position).Magnitude
            
            print("DEBUG: Menuju telur di " .. tostring(targetEgg.Position) .. " | Jarak: " .. math.floor(distance))
            
            -- Eksekusi Teleport (Metode CFrame murni)
            hrp.CFrame = CFrame.new(targetPos)
            
            task.wait(0.5) -- Memberi waktu server sinkronisasi
            
            print("DEBUG: Mencoba memicu ProximityPrompt...")
            if fireproximityprompt then
                fireproximityprompt(prompt)
                print("DEBUG: fireproximityprompt berhasil dipanggil.")
            else
                prompt.HoldDuration = 0
                prompt:InputHoldBegin()
                prompt:InputHoldEnd()
                print("DEBUG: Metode input manual digunakan.")
            end
        end
    else
        print("DEBUG: Menunggu telur muncul atau semua telur sudah diambil.")
    end
end
