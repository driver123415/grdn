local function refreshTargetBtnText()
    if #CONFIG.TargetUnits == 0 then TargetDropdownBtn.Text = "📋 Pilih Unit Target (0 Terpilih)"
    elseif #CONFIG.TargetUnits == 1 then TargetDropdownBtn.Text = "Target: " .. CONFIG.TargetUnits[1]
    else TargetDropdownBtn.Text = "Target: " .. #CONFIG.TargetUnits .. " Unit Terpilih" end
end

local function updateDropdownList()
    for _, child in ipairs(DropdownMenuScroll:GetChildren()) do
        if child:IsA("TextButton") then child:Destroy() end
    end
    
    local uniqueUnits = {}
    local mapFolder = workspace:FindFirstChild("Map")
    local entitiesFolder = mapFolder and mapFolder:FindFirstChild("Entities")
    
    -- Ambil dari Workspace
    if entitiesFolder then
        for _, unit in ipairs(entitiesFolder:GetChildren()) do
            if not uniqueUnits[unit.Name] and (unit.Name:match("unit_") or unit.Name:match("enemy_") or unit:GetAttribute("ID")) then
                uniqueUnits[unit.Name] = true
            end
        end
    end
    -- Ambil juga dari UI (Super Aman)
    local sf = getUnitScrollingFrame()
    if sf then
        for _, child in ipairs(sf:GetChildren()) do
            if child:IsA("Frame") and not uniqueUnits[child.Name] then
                uniqueUnits[child.Name] = true
            end
        end
    end
    
    for unitName, _ in pairs(uniqueUnits) do
        local isSelected = table.find(CONFIG.TargetUnits, unitName) ~= nil
        local btn = Instance.new("TextButton")
        btn.Size = UDim2.new(1, 0, 0, 22)
        btn.BackgroundColor3 = isSelected and Color3.fromRGB(60, 120, 60) or Color3.fromRGB(40, 40, 55)
        btn.Text = unitName
        btn.TextColor3 = Color3.fromRGB(255, 255, 255)
        btn.Font = Enum.Font.Gotham btn.TextSize = 10 btn.BorderSizePixel = 0 btn.Parent = DropdownMenuScroll
        
        btn.MouseButton1Click:Connect(function()
            local idx = table.find(CONFIG.TargetUnits, unitName)
            if idx then table.remove(CONFIG.TargetUnits, idx) btn.BackgroundColor3 = Color3.fromRGB(40, 40, 55)
            else table.insert(CONFIG.TargetUnits, unitName) btn.BackgroundColor3 = Color3.fromRGB(60, 120, 60) end
            refreshTargetBtnText()
        end)
    end
    DropdownMenuScroll.CanvasSize = UDim2.new(0, 0, 0, DropdownMenuLayout.AbsoluteContentSize.Y)
end

TargetDropdownBtn.MouseButton1Click:Connect(function()
    DropdownOverlay.Visible = not DropdownOverlay.Visible
    if DropdownOverlay.Visible then
        -- Mendaratkan dropdown persis di bawah tombol secara dinamis
        local absPos = TargetDropdownBtn.AbsolutePosition
        local absSize = TargetDropdownBtn.AbsoluteSize
        DropdownOverlay.Position = UDim2.new(0, absPos.X, 0, absPos.Y + absSize.Y + 2)
        DropdownOverlay.Size = UDim2.new(0, absSize.X, 0, 120)
        updateDropdownList()
    end
end)

