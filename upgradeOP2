ToggleBtn.MouseButton1Click:Connect(toggleScript)

task.spawn(function()
    while task.wait(1) do
        local curWaveText = getWaveText()
        if curWaveText and curWaveText ~= "" then
            WaveTextDisplay.Text = "Wave: " .. curWaveText
            local extractedNumStr = string.match(curWaveText, "Wave%s*(%d+)")
            if extractedNumStr then
                local currentWaveNum = tonumber(extractedNumStr)
                if currentWaveNum ~= lastWaveNum then
                    lastWaveNum = currentWaveNum
                    if CONFIG.WaveControl then
                        if currentWaveNum == CONFIG.StartWave and not isRunning then
                            addLog("🎯 Wave " .. currentWaveNum .. " Tercapai! Auto-Start ON", Color3.fromRGB(100, 255, 100))
                            toggleScript()
                        elseif currentWaveNum == CONFIG.StopWave and isRunning then
                            addLog("🛑 Wave " .. currentWaveNum .. " Tercapai! Auto-Stop ON", Color3.fromRGB(255, 100, 100))
                            toggleScript()
                        end
                    end
                end
            end
        end
    end
end)

-- ============================================================
-- CORE LOGIC (AUTO UPGRADE DENGAN LEVEL CHECKER)
-- ============================================================
local UpgradeRemote = ReplicatedStorage:WaitForChild("RemoteFunctions"):WaitForChild("UpgradeUnit")

function runUpgrader()
    addLog("Sistem Cerdas Mulai (Anti-Spam Aktif!)", Color3.fromRGB(100, 255, 100))

    while isRunning do
        local mapFolder = workspace:FindFirstChild("Map")
        local entitiesFolder = mapFolder and mapFolder:FindFirstChild("Entities")
        local sfUI = getUnitScrollingFrame()
        
        if not entitiesFolder or #CONFIG.TargetUnits == 0 then
            task.wait(CONFIG.UpgradeInterval)
            continue
        end

        local totalMaxFiltered = 0
        local totalNeedUpgrade = 0

        for _, targetName in ipairs(CONFIG.TargetUnits) do
            if not isRunning then break end
            
            -- Kumpulkan ID dari Workspace
            local wsUnits = {}
            for _, unit in pairs(entitiesFolder:GetChildren()) do
                if unit.Name == targetName then
                    local id = unit:GetAttribute("ID") 
                    if id then table.insert(wsUnits, id) end
                end
            end
            
            -- Kumpulkan Frame dari UI
            local uiFrames = {}
            if sfUI then
                for _, child in ipairs(sfUI:GetChildren()) do
                    if child.Name == targetName then table.insert(uiFrames, child) end
                end
            end
            
            -- PASANGKAN MEREKA: ID ke-1 dipasangkan dengan UI ke-1
            local toUpgradeIDs = {}
            for i = 1, #wsUnits do
                local isMax = false
                if uiFrames[i] then
                    isMax = isUIMaxLevel(uiFrames[i])
                end
                
                if isMax then totalMaxFiltered = totalMaxFiltered + 1
                else table.insert(toUpgradeIDs, wsUnits[i]) end
            end
            
            totalNeedUpgrade = totalNeedUpgrade + #toUpgradeIDs
            
            -- Eksekusi hanya untuk yang belum max level
            if #toUpgradeIDs > 0 then
                addLog("Upgrading ["..targetName.."] ("..#toUpgradeIDs.." unit)", Color3.fromRGB(100, 200, 255))
                for _, id in ipairs(toUpgradeIDs) do
                    if not isRunning then break end
                    task.spawn(function()
                        pcall(function() UpgradeRemote:InvokeServer(id) end)
                    end)
                end
            end
        end

        CountText.Text = "Butuh Upg: " .. totalNeedUpgrade .. " | Selesai (Max): " .. totalMaxFiltered
        task.wait(CONFIG.UpgradeInterval)
    end
end

