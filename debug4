-- Fungsi menyusun path
local function getFullPath(obj)
    local path = obj.Name
    local current = obj.Parent
    while current and current ~= game do
        if string.match(current.Name, "%s") then
            path = '["' .. current.Name .. '"].' .. path
        else
            path = current.Name .. "." .. path
        end
        current = current.Parent
    end
    return path
end

-- Animasi flash tombol saat dicopy
local function flashButton(btn)
    local oriColor = btn.BackgroundColor3
    local oriText = btn.Text
    btn.BackgroundColor3 = Color3.fromRGB(50, 200, 50)
    btn.Text = "Copied!"
    task.wait(1)
    btn.BackgroundColor3 = oriColor
    btn.Text = oriText
end

-- Membuat Frame Hasil per Layer
local function createResultFrame(layerNum, obj)
    local frame = Instance.new("Frame")
    frame.Size = UDim2.new(1, -10, 0, 75)
    frame.BackgroundColor3 = Color3.fromRGB(45, 45, 45)
    frame.BorderSizePixel = 0
    Instance.new("UICorner", frame).CornerRadius = UDim.new(0, 6)
    
    local title = Instance.new("TextLabel")
    title.Size = UDim2.new(1, -10, 0, 20)
    title.Position = UDim2.new(0, 5, 0, 5)
    title.BackgroundTransparency = 1
    title.Text = "Layer " .. layerNum .. " : [" .. obj.ClassName .. "] " .. obj.Name
    title.TextColor3 = Color3.fromRGB(255, 200, 100)
    title.Font = Enum.Font.GothamBold
    title.TextSize = 12
    title.TextXAlignment = Enum.TextXAlignment.Left
    title.Parent = frame
    
    local pathDisplay = Instance.new("TextLabel")
    pathDisplay.Size = UDim2.new(0.7, 0, 0, 40)
    pathDisplay.Position = UDim2.new(0, 5, 0, 25)
    pathDisplay.BackgroundTransparency = 1
    pathDisplay.Text = getFullPath(obj)
    pathDisplay.TextColor3 = Color3.fromRGB(200, 200, 200)
    pathDisplay.Font = Enum.Font.Code
    pathDisplay.TextSize = 10
    pathDisplay.TextXAlignment = Enum.TextXAlignment.Left
    pathDisplay.TextYAlignment = Enum.TextYAlignment.Top
    pathDisplay.TextWrapped = true
    pathDisplay.Parent = frame
    
    local copyBtn = Instance.new("TextButton")
    copyBtn.Size = UDim2.new(0.25, 0, 0, 25)
    copyBtn.Position = UDim2.new(0.72, 0, 0, 30)
    copyBtn.BackgroundColor3 = Color3.fromRGB(0, 150, 200)
    copyBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
    copyBtn.Font = Enum.Font.GothamBold
    copyBtn.TextSize = 11
    copyBtn.Text = "Copy Path"
    Instance.new("UICorner", copyBtn).CornerRadius = UDim.new(0, 4)
    copyBtn.Parent = frame
    
    copyBtn.MouseButton1Click:Connect(function()
        if pcall(function() setclipboard(getFullPath(obj)) end) then
            flashButton(copyBtn)
        end
    end)
    
    -- Tambahkan keterangan Teks jika ada
    if obj:IsA("TextLabel") or obj:IsA("TextButton") then
        local textInfo = Instance.new("TextLabel")
        textInfo.Size = UDim2.new(1, -10, 0, 15)
        textInfo.Position = UDim2.new(0, 5, 0, 60)
        textInfo.BackgroundTransparency = 1
        textInfo.Text = "Text: '" .. tostring(obj.Text) .. "'"
        textInfo.TextColor3 = Color3.fromRGB(150, 255, 150)
        textInfo.Font = Enum.Font.Gotham
        textInfo.TextSize = 11
        textInfo.TextXAlignment = Enum.TextXAlignment.Left
        textInfo.Parent = frame
        frame.Size = UDim2.new(1, -10, 0, 80) -- Perbesar frame sedikit
    end
    
    frame.Parent = ResultsScroll
end

-- Menyadap Input Klik
if _G.UIClickDebuggerConnection then
    _G.UIClickDebuggerConnection:Disconnect()
end

_G.UIClickDebuggerConnection = UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if not isScanning then return end
    
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        local posX = input.Position.X
        local posY = input.Position.Y
        
        local guiObjects = playerGui:GetGuiObjectsAtPosition(posX, posY)
        
        if #guiObjects > 0 then
            -- Bersihkan hasil sebelumnya agar tidak numpuk terlalu panjang
            for _, child in ipairs(ResultsScroll:GetChildren()) do
                if child:IsA("Frame") then child:Destroy() end
            end
            
            local count = 0
            for i, obj in ipairs(guiObjects) do
                -- Jangan memindai UI dari Debugger ini sendiri
                if not obj:IsDescendantOf(ScreenGui) then
                    count = count + 1
                    createResultFrame(count, obj)
                    
                    -- Batasi maksimal 6 lapisan teratas agar tidak lag
                    if count >= 6 then break end
                end
            end
            
            -- Otomatis matikan scanner setelah 1x klik sukses
            isScanning = false
            ToggleScannerBtn.Text = "Scanner Status: OFF"
            ToggleScannerBtn.BackgroundColor3 = Color3.fromRGB(200, 80, 80)
        end
    end
end)
