-- =========================================================
-- [BATCH FARM] VERSI MALAS MODIF (SCAN -> LIST -> DELETE)
-- =========================================================

local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer

print("--- [MODIF] Script Dimulai: Sistem Antrean Aktif ---")

while task.wait(1) do
    local character = LocalPlayer.Character
    if not character or not character:FindFirstChild("HumanoidRootPart") then 
        print("DEBUG: Menunggu Karakter Spawn...")
        continue 
    end

    local hrp = character.HumanoidRootPart
    
    -- 1. MENGAMBIL SEMUA KOORDINAT (Scanning)
    local antreanTelur = {}
    for _, obj in pairs(workspace:GetChildren()) do
        if obj.Name == "Collectable" and obj:IsA("BasePart") then
            table.insert(antreanTelur, obj)
        end
    end

    print("DEBUG: Berhasil mendeteksi " .. #antreanTelur .. " telur. Memulai perjalanan...")

    -- 2. TELEPORT 1 PER 1 KE KOORDINAT YANG DIDAPATKAN
    for _, telur dalam ipairs(antreanTelur) do
        -- Cek apakah telur masih ada (belum dihapus script lain)
        if telur and telur.Parent then
            local targetPos = telur.Position + Vector3.new(0, 3, 0)
            local prompt = telur:FindFirstChildWhichIsA("ProximityPrompt")

            print("DEBUG: Teleport ke posisi: " .. tostring(targetPos))
            
            -- METODE TELEPORT ANDALANMU
            hrp.CFrame = CFrame.new(targetPos)

            -- Jeda sebentar agar server sinkron
            task.wait(0.4)

            -- 3. TRIGGER PROXIMITY PROMPT
            if prompt then
                if fireproximityprompt then
                    fireproximityprompt(prompt)
                else
                    prompt.HoldDuration = 0
                    prompt:InputHoldBegin()
                    prompt:InputHoldEnd()
                end
                print("DEBUG: Prompt dipicu.")
            end

            -- 4. OTOMATIS MENGHAPUS OBJEK (Local Delete)
            -- Ini agar script tidak mendatangi koordinat ini lagi di loop berikutnya
            telur:Destroy()
            print("DEBUG: Objek dihapus dari Workspace Lokal.")
            
            task.wait(0.5) -- Jeda antar telur
        end
    end
    
    print("--- [MODIF] Antrean Selesai. Mencari telur baru... ---")
end
